generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum ListingType {
  RENT
  SALE
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
}

enum PropertySubType {
  APARTMENT
  VILLA
  OFFICE
  SHOP
  WAREHOUSE
  SHOWROOM
  PLOT
  OTHER
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum UrgencyLevel {
  NORMAL
  URGENT
  VERY_URGENT
}

enum PropertyStatus {
  NEW
  REVIEW
  APPROVED
  REJECTED
}

enum BrokerType {
  OWNER
  BROKER
  BUILDER
}

enum TenantPreference {
  HINDU_ONLY
  MUSLIM_ONLY
  VEG_ONLY
  NO_SMOKING
  FAMILY_ONLY
  BACHELORS_ALLOWED
  COMPANY_LEASE_ONLY
}

enum TenantType {
  BACHELORS
  FAMILY
  GIRLS
  BOYS
  ANY
}



enum LeadStage {
  NEW
  CONTACTED
  VISIT
  NEGOTIATION
  CLOSED
  LOST
}


//////////////////////
// MODELS
//////////////////////

model PropertyActivity {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  action     String   // CREATED, UPDATED, APPROVED, REJECTED
  oldData    Json?
  newData    Json?
  
  createdAt  DateTime @default(now())

  userId      String?
  userName    String?
  

  @@index([propertyId])

}

model Message {
  id         String     @id @default(uuid())
  groupName  String
  messageKey String     @unique
  rawText    String
  receivedAt DateTime   @default(now())
  properties Property[]
}

model Property {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id])

  firmName        String?
  agentName       String?
  contacts        String[]
  senderContact   String?
  rawContactBlock String?

  // 🏠 Listing classification
  listingType      ListingType?
  propertyCategory PropertyCategory?
  propertySubType  PropertySubType?

  // 🌍 Location system
  country  String?
  city     String?
  area     String?
  location String? // full raw address text

  // 💰 Deal data
  price       BigInt?
  deposit     BigInt?
  bhk         String?
  areaSqft    Int?
  furnishing  FurnishingType?
  building    String?
  floor       Int?
  totalFloors Int?

  // 🧠 Intelligence
  urgencyLevel  UrgencyLevel @default(NORMAL)
  negotiable    Boolean?
  availableFrom DateTime?

  // 🧍 Preferences
  tenantTypes        TenantType[] @default([])
  tenantRestrictions String[]     @default([])

  brokerType BrokerType?

  // 🤖 AI + Admin
  confidence   Float
  status       PropertyStatus?
  availability String

  // 📊 SaaS tracking
  sourceGroup     String?
  duplicateOf     String?
  converted       Boolean   @default(false)

  //📈 Lead Management
  leadStage        LeadStage @default(NEW)
  followUpAt       DateTime?
  lastContactedAt  DateTime?
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  media     Media[]

  activities PropertyActivity[]
  shares    PropertyShare[]
  propertyAgents PropertyAgent[]
  clientProperties ClientProperty[]
}

model Media {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  url        String
  type       String
}

model PropertyShare {
  id            String   @id @default(cuid())
  propertyId    String

  platform      String   // WHATSAPP_DIRECT, WHATSAPP_GROUP, FACEBOOK, 99ACRES
  targetType    String   // PERSON, GROUP, PAGE, PORTAL
  targetName    String?
  targetContact String?

  // 🧠 LEAD FIELDS (THIS IS THE REAL CRM)
  leadStage     LeadStage @default(NEW)
  followUpAt    DateTime?
  lastContactedAt DateTime?
  notes         String?

  leadId        String?
  sentAt        DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])
}

model Agent {
  id        String @id @default(uuid())

  name      String?
  firmName  String?
  isMerged    Boolean  @default(false)

  mergedFrom Agent[] @relation("AgentMerge")
  mergedInto   Agent? @relation("AgentMerge", fields: [mergedIntoId], references: [id])
  mergedIntoId String?
  mergedAt    DateTime?

  phones    AgentPhone[]
  properties PropertyAgent[]
  propertyCount   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model AgentPhone {
  id        String @id @default(uuid())

  phone     String @unique

  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}


model PropertyAgent {
  id         String @id @default(uuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([propertyId, agentId])
}

model IngestionLog {
  id         String   @id @default(uuid())
  propertyId String?

  level      String   // INFO | WARN | ERROR
  code       String   // e.g. NAME_CONFLICT, TOO_MANY_AGENTS, NO_AGENT_FOUND
  message    String

  payload    Json?

  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([code])
}

model AgentMergeLog {
  id            String   @id @default(uuid())
  fromAgentId   String
  toAgentId     String
  mergedBy      String
  mergedAt      DateTime @default(now())
  reason        String?
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  phone     String
  createdAt DateTime @default(now())
}

model Client {
  id        String   @id @default(uuid())
  name      String?
  phone     String   @unique

  status    String   @default("ACTIVE") // ACTIVE | COLD | CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties ClientProperty[]
  events     ClientEvent[]
}

model ClientProperty {
  id         String   @id @default(uuid())

  clientId   String
  propertyId String

  status     LeadStage @default(NEW)
  sharedAt   DateTime  @default(now())
  followUpAt    DateTime?   // ✅ ADD THIS
  lastActionAt DateTime?
  lastContactedAt DateTime?

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([clientId, propertyId])
  @@index([clientId])
}

model ClientEvent {
  id        String   @id @default(uuid())

  clientId  String
  type      String   // PROPERTY_SHARED, NOTE_ADDED, STATUS_CHANGED, MESSAGE_RECEIVED
  metadata  Json?

  createdAt DateTime @default(now())

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}
