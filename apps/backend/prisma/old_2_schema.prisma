generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS — PLATFORM / AUTH
// ============================================================

/// Your company's internal role system — sits above all workspaces.
enum PlatformRole {
  SUPERADMIN  // you (CEO/founder) — full read/write on everything
  SUPPORT     // service team — read + limited actions, no billing/delete
  USER        // every broker / firm owner (default)
}

/// Whether an account is a solo broker or a firm with multiple brokers.
enum WorkspaceType {
  INDIVIDUAL  // one person, one login
  FIRM        // one firm, multiple broker profiles
}

/// What a member can do inside a workspace.
enum MemberRole {
  OWNER   // full access + billing + invite/remove members
  BROKER  // standard — own leads, properties, clients
  VIEWER  // read-only (accountant, assistant)
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// ============================================================
// ENUMS — PROPERTY / CRM (unchanged from your original)
// ============================================================

enum ListingType {
  RENT
  SALE
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
}

enum PropertySubType {
  APARTMENT
  VILLA
  OFFICE
  SHOP
  WAREHOUSE
  SHOWROOM
  PLOT
  OTHER
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum UrgencyLevel {
  NORMAL
  URGENT
  VERY_URGENT
}

enum PropertyStatus {
  NEW
  REVIEW
  APPROVED
  REJECTED
}

enum BrokerType {
  OWNER
  BROKER
  BUILDER
}

enum TenantPreference {
  HINDU_ONLY
  MUSLIM_ONLY
  VEG_ONLY
  NO_SMOKING
  FAMILY_ONLY
  BACHELORS_ALLOWED
  COMPANY_LEASE_ONLY
}

enum TenantType {
  BACHELORS
  FAMILY
  GIRLS
  BOYS
  ANY
}

enum LeadStage {
  NEW
  CONTACTED
  VISIT
  NEGOTIATION
  CLOSED
  LOST
}

// ============================================================
// PLATFORM LAYER — your company's models
// ============================================================

/// The top-level tenant container.
/// Every piece of data on the platform belongs to a workspace.
/// INDIVIDUAL = one broker. FIRM = multiple brokers under one account.
model Workspace {
  id        String        @id @default(uuid())
  name      String                            // "Sharma Properties" or "Rahul Verma"
  slug      String        @unique             // url-safe: "sharma-properties"
  type      WorkspaceType                     // INDIVIDUAL | FIRM

  // Contact info for the workspace
  email     String?
  phone     String?
  city      String?
  logoUrl   String?

  // Plan — extended by Subscription model
  plan      String        @default("FREE")    // FREE | INDIVIDUAL | FIRM

  isActive  Boolean       @default(true)      // platform can suspend a workspace
  suspendedAt DateTime?
  suspendedReason String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  subscription  Subscription?
  invoices      Invoice[]
  flagOverrides FeatureFlagOverride[]

  // Tenant-scoped CRM data
  messages    Message[]
  properties  Property[]
  agents      Agent[]
  clients     Client[]

  @@index([type])
  @@index([plan])
  @@index([createdAt])
}

/// Auth identity — one per human being.
/// platformRole determines access above the workspace level.
model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String

  name          String?
  phone         String?
  avatarUrl     String?

  // Platform-level access (your company's roles)
  platformRole  PlatformRole @default(USER)

  // Email verification
  emailVerified    Boolean   @default(false)
  verifyToken      String?   @unique
  verifyTokenExp   DateTime?

  // Password reset
  resetToken       String?   @unique
  resetTokenExp    DateTime?

  // Soft delete — deactivated users can't login but data is preserved
  isActive         Boolean   @default(true)
  deactivatedAt    DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memberships   WorkspaceMember[]
  invitesSent   WorkspaceInvite[]   @relation("InvitedBy")
  sessions      UserSession[]
  notifications Notification[]

  // Platform audit trail — every action this user ever took
  auditLogs     AuditLog[]
  impersonationsPerformed ImpersonationLog[] @relation("AdminUser")
  impersonationsReceived  ImpersonationLog[] @relation("TargetUser")

  @@index([platformRole])
  @@index([createdAt])
}

/// Join table between User and Workspace.
/// One user can theoretically be in multiple workspaces (future: freelance brokers).
model WorkspaceMember {
  id          String     @id @default(uuid())

  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        MemberRole @default(BROKER)

  // Which invite created this membership (nullable for the first owner)
  inviteId    String?

  joinedAt    DateTime   @default(now())
  lastActiveAt DateTime?  // updated on every request — useful for "last seen" and churn detection

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

/// Pending invitations — firm owners use these to add brokers to their workspace.
model WorkspaceInvite {
  id          String       @id @default(uuid())

  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  email       String
  role        MemberRole   @default(BROKER)
  token       String       @unique   // secure random token in the invite link
  status      InviteStatus @default(PENDING)

  expiresAt   DateTime                       // now() + 7 days typically
  acceptedAt  DateTime?

  invitedById String
  invitedBy   User         @relation("InvitedBy", fields: [invitedById], references: [id])

  createdAt   DateTime     @default(now())

  @@index([workspaceId])
  @@index([token])
  @@index([email])
}

/// JWT refresh token sessions — one row per logged-in device.
/// Allows multi-device login, forced logout, and token rotation.
model UserSession {
  id            String   @id @default(uuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken  String   @unique   // stored as a hash, never plain text
  userAgent     String?
  ipAddress     String?
  deviceName    String?            // "iPhone 15", "Chrome on MacBook"

  expiresAt     DateTime
  revokedAt     DateTime?          // set on logout or token rotation

  createdAt     DateTime @default(now())

  @@index([userId])
}

/// Platform-wide audit log — every meaningful action ever taken.
/// Queryable by workspace, user, entity type, or action.
/// This is your legal cover, your debugging tool, and a premium feature for firm owners.
model AuditLog {
  id          String   @id @default(uuid())

  // Who
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspaceId String?  // null = platform-level action (superadmin doing something)

  // What
  action      String   // PROPERTY_CREATED, CLIENT_DELETED, MEMBER_INVITED, LOGIN_FAILED, PLAN_UPGRADED
  entity      String   // "Property", "Client", "User", "Workspace"
  entityId    String?  // the id of the record that changed

  // State change
  before      Json?    // snapshot before change
  after       Json?    // snapshot after change

  // Context
  ipAddress   String?
  userAgent   String?
  requestId   String?  // trace ID for correlating with server logs

  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

/// Support team can log in as any user to help them.
/// Every impersonation session is recorded for compliance.
model ImpersonationLog {
  id                String   @id @default(uuid())

  adminUserId       String
  adminUser         User     @relation("AdminUser", fields: [adminUserId], references: [id])

  targetUserId      String
  targetUser        User     @relation("TargetUser", fields: [targetUserId], references: [id])

  targetWorkspaceId String

  reason            String?  // support ticket ID, customer complaint ref, etc.

  startedAt         DateTime @default(now())
  endedAt           DateTime?

  ipAddress         String?

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([targetWorkspaceId])
}

// ============================================================
// BILLING
// ============================================================

/// One subscription per workspace.
model Subscription {
  id          String             @id @default(uuid())

  workspaceId String             @unique
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  plan        String             // INDIVIDUAL | FIRM_5 | FIRM_20 | ENTERPRISE
  status      SubscriptionStatus @default(TRIALING)
  interval    BillingInterval    @default(MONTHLY)

  // Payment gateway IDs (Razorpay or Stripe)
  gatewayCustomerId      String?
  gatewaySubscriptionId  String?

  seats            Int      @default(1)   // max WorkspaceMembers allowed
  seatsUsed        Int      @default(1)

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices    Invoice[]
}

model Invoice {
  id              String   @id @default(uuid())

  workspaceId     String
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  amount          Int          // in paise (₹1 = 100 paise)
  currency        String       @default("INR")
  status          String       // PAID | UNPAID | VOID | REFUNDED

  // Gateway
  gatewayInvoiceId  String?
  gatewayPaymentId  String?

  paidAt          DateTime?
  dueAt           DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?

  createdAt       DateTime @default(now())

  @@index([workspaceId])
}

// ============================================================
// FEATURE FLAGS
// ============================================================

/// Platform-wide feature toggles with per-workspace overrides.
/// Use this to gate beta features, plan-specific features, or to give
/// specific workspaces early access.
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique  // "ai_valuation", "bulk_export", "api_access", "advanced_analytics"
  description String?
  enabled     Boolean  @default(false)  // global default

  overrides   FeatureFlagOverride[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeatureFlagOverride {
  id          String      @id @default(uuid())

  flagId      String
  flag        FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  enabled     Boolean

  @@unique([flagId, workspaceId])
  @@index([workspaceId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

/// Every notification sent to any user on any channel.
/// In-app, email, WhatsApp, and push — all in one table.
model Notification {
  id          String              @id @default(uuid())

  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?

  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)

  title       String
  body        String
  data        Json?               // { propertyId, clientId, followUpAt, ... }
  actionUrl   String?             // deep link to open in the app

  sentAt      DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failReason  String?

  createdAt   DateTime @default(now())

  @@index([userId, status])
  @@index([workspaceId])
  @@index([createdAt])
}

// ============================================================
// USAGE / TELEMETRY — your data goldmine
// ============================================================

/// Every meaningful user action metered here.
/// Powers: product analytics, pricing levers, AI training, churn prediction.
/// Examples: "property.parsed", "client.called", "whatsapp.sent", "property.viewed"
model UsageEvent {
  id          String   @id @default(uuid())

  workspaceId String
  userId      String?

  event       String   // namespaced: "property.created", "client.followup.set", "share.whatsapp"
  properties  Json?    // arbitrary context: { propertyId, source, duration, bhk, city, ... }

  occurredAt  DateTime @default(now())

  @@index([workspaceId, event])
  @@index([workspaceId, occurredAt])
  @@index([event, occurredAt])   // platform-wide: "how many WhatsApp shares happened today?"
  @@index([userId, occurredAt])  // per-user activity heatmap
}

// ============================================================
// GEOGRAPHY — normalised area data (future goldmine)
// ============================================================

/// Normalised area/locality model.
/// Attach to properties over time — then you can compute:
/// avg price per BHK per area, demand heatmaps, AI price suggestions.
model Area {
  id       String   @id @default(uuid())
  city     String
  name     String           // "Bandra West", "Koregaon Park"
  aliases  String[]         // ["bandra w", "bandra-west", "bandra (w)"]
  lat      Float?
  lng      Float?
  pincode  String?

  properties Property[]

  @@unique([city, name])
  @@index([city])
}

// ============================================================
// EXISTING MODELS — updated with workspaceId + fixes
// ============================================================

model PropertyActivity {
  id         String   @id @default(uuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  action     String   // CREATED, UPDATED, APPROVED, REJECTED, STATUS_CHANGED
  oldData    Json?
  newData    Json?

  userId     String?  // which workspace member did this
  userName   String?

  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([createdAt])
}

model Message {
  id         String    @id @default(uuid())
  groupName  String
  messageKey String    @unique
  rawText    String
  receivedAt DateTime  @default(now())

  // Workspace isolation
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  properties  Property[]

  @@index([workspaceId])
  @@index([workspaceId, receivedAt])
}

model Property {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id])

  // Workspace isolation (denormalised from Message for fast direct queries)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Which workspace member owns/created this record
  ownerId     String?   // references User.id

  // Normalised area (optional — populate over time)
  areaId      String?
  areaRef     Area?     @relation(fields: [areaId], references: [id])

  firmName        String?
  agentName       String?
  contacts        String[]
  senderContact   String?
  rawContactBlock String?

  listingType      ListingType?
  propertyCategory PropertyCategory?
  propertySubType  PropertySubType?

  country  String?
  city     String?
  area     String?     // raw text (keep for display; areaId is the normalised ref)
  location String?

  price       BigInt?
  deposit     BigInt?
  bhk         String?
  areaSqft    Int?
  furnishing  FurnishingType?
  building    String?
  floor       Int?
  totalFloors Int?

  urgencyLevel  UrgencyLevel @default(NORMAL)
  negotiable    Boolean?
  availableFrom DateTime?

  tenantTypes        TenantType[] @default([])
  tenantRestrictions String[]     @default([])

  brokerType BrokerType?

  confidence   Float
  status       PropertyStatus?
  availability String

  sourceGroup  String?
  duplicateOf  String?
  converted    Boolean  @default(false)

  // NOTE: leadStage and followUpAt removed from Property.
  // Lead tracking lives exclusively on ClientProperty.
  // This eliminates the dual source-of-truth problem.
  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  media            Media[]
  activities       PropertyActivity[]
  shares           PropertyShare[]
  propertyAgents   PropertyAgent[]
  clientProperties ClientProperty[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, city])
  @@index([areaId])
}

model Media {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  type       String   // IMAGE | VIDEO | DOCUMENT
}

model PropertyShare {
  id            String   @id @default(cuid())
  propertyId    String

  // Workspace isolation
  workspaceId   String

  platform      String   // WHATSAPP_DIRECT, WHATSAPP_GROUP, FACEBOOK, 99ACRES
  targetType    String   // PERSON, GROUP, PAGE, PORTAL
  targetName    String?
  targetContact String?

  leadStage       LeadStage @default(NEW)
  followUpAt      DateTime?
  lastContactedAt DateTime?
  notes           String?

  // leadId removed — link to Client.id instead if you need this
  clientId        String?

  sentAt          DateTime @default(now())

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([propertyId])
}

model Agent {
  id          String @id @default(uuid())

  // Workspace isolation
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String?
  firmName    String?
  isMerged    Boolean  @default(false)

  mergedFrom   Agent[]  @relation("AgentMerge")
  mergedInto   Agent?   @relation("AgentMerge", fields: [mergedIntoId], references: [id])
  mergedIntoId String?
  mergedAt     DateTime?

  phones        AgentPhone[]
  properties    PropertyAgent[]
  propertyCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model AgentPhone {
  id      String @id @default(uuid())
  phone   String

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Phone unique per workspace (via Agent), not globally
  @@unique([agentId, phone])
}

model PropertyAgent {
  id         String @id @default(uuid())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([propertyId, agentId])
}

model IngestionLog {
  id         String   @id @default(uuid())

  workspaceId String?  // which workspace this ingestion was for
  propertyId  String?

  level      String   // INFO | WARN | ERROR
  code       String   // NAME_CONFLICT, TOO_MANY_AGENTS, NO_AGENT_FOUND, PARSE_FAILED
  message    String
  payload    Json?

  createdAt  DateTime @default(now())

  @@index([workspaceId])
  @@index([propertyId])
  @@index([code])
  @@index([createdAt])
}

model AgentMergeLog {
  id          String   @id @default(uuid())
  fromAgentId String
  toAgentId   String
  mergedBy    String   // User.id of who triggered the merge
  mergedAt    DateTime @default(now())
  reason      String?
}

// TeamMember REMOVED — replaced by WorkspaceMember + User

model Client {
  id    String  @id @default(uuid())
  name  String?

  // Workspace isolation — same phone can exist in different workspaces
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  status    String   @default("ACTIVE")  // ACTIVE | COLD | CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phones      ClientPhone[]      // multiple phones like AgentPhone
  properties  ClientProperty[]
  events      ClientEvent[]

  @@unique([workspaceId, id])
  @@index([workspaceId])
}

/// Separate phone table for clients — mirrors AgentPhone.
/// Allows multiple numbers per client and future duplicate merging.
model ClientPhone {
  id       String @id @default(uuid())
  phone    String
  label    String?   // "personal", "office", "WhatsApp"
  primary  Boolean   @default(false)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clientId, phone])
  @@index([phone])  // fast lookup: "which client has this number?"
}

model ClientProperty {
  id         String @id @default(uuid())

  clientId   String
  propertyId String

  // All lead tracking lives HERE, not on Property
  status          LeadStage @default(NEW)
  sharedAt        DateTime  @default(now())
  followUpAt      DateTime?
  lastActionAt    DateTime?
  lastContactedAt DateTime?
  notes           String?

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([clientId, propertyId])
  @@index([clientId])
  @@index([propertyId])
  @@index([followUpAt])   // fast query: "all follow-ups due today"
}

model ClientEvent {
  id       String @id @default(uuid())
  clientId String
  type     String  // PROPERTY_SHARED, NOTE_ADDED, STATUS_CHANGED, CALLED, WHATSAPP_SENT
  metadata Json?

  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, createdAt])
}
